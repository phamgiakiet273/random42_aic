# Copy to .env and fill in real values. Never commit the real .env (already gitignored).
# All variables map 1:1 to fields in src/utils/settings.py.

# --- Basic ---
TRANSFORMERS_CACHE=data/weights
CUDA_DEVICE_ORDER=PCI_BUS_ID
REQUEST_TIMEOUT=30
TIMEOUT_KEEP_ALIVE=30
# Real HuggingFace access token (needed to download gated model weights). Rotate if ever leaked.
HUGGINGFACE_HUB_TOKEN=

# --- Dataset / metadata paths (mounted into containers under ./data) ---
BASE_PATH=data
DATASET_PATH_ORIGIN=data/original
DATASET_PATH_TEAM=data
KEYFRAME_FOLDER_PATH=data
SPLIT_NAME=autoshot
SPLIT_NAME_LOW_RES=low_res_autoshot
LOWRES_FORMAT=.avif
DATASET_INDEX=data/index
# JSON arrays (double-quoted), one path per dataset batch.
S2T_PATH=["data/0/speech_to_text/transcript_all_autoshot_segmented.json", "data/1/speech_to_text/transcript_all_autoshot_segmented.json"]
OBJECT_PATH=data/utils/object/total_0_1.json
FPS_PATH=["data/0/fps/video_fps_0.json", "data/1/fps/video_fps_1.json"]
SHOT_PATH=["data/0/shot/shot_0.json", "data/1/shot/shot_1.json"]

# --- Hub gateway ---
HUB_HOST=0.0.0.0
HUB_PORT=9021
HUB_MAX_WORKERS=5
# Public base URL the hub is served from (used to build absolute links in the UI).
BASE_URL=http://localhost:9021/

# --- Result manager ---
RESULT_MANAGER_HOST=0.0.0.0
RESULT_MANAGER_PORT=9022
RESULT_MANAGER_MAX_WORKERS=5

# --- Media server (nginx / media_server compose service, part of docker-compose-server.yml) ---
# `hub` runs separately (docker-compose-local.yml) from everything below, so these must be
# reachable over the network, e.g. your GPU server's hostname/IP -- not "localhost" or a
# docker-compose service name unless hub and the server stack share a Docker network.
NGINX_IMAGE_HOST=http://your-server-host:9027/img
NGINX_VIDEO_HOST=http://your-server-host:9027/video
NGINX_IMAGE_PORT=9027
NGINX_VIDEO_PORT=9027

# --- SIGLIP v2 (alpha) ---
SIGLIP_V2_HOST=0.0.0.0
SIGLIP_V2_PORT=9029
# hub (local) reaches this over the network; services inside docker-compose-server.yml reach
# each other by compose service name instead (e.g. http://siglip_alpha:9029).
SIGLIP_V2_HOST_PUBLIC=http://your-server-host:9029
SIGLIP_V2_MAX_WORKERS=1
SIGLIP_V2_CUDA_VISIBLE_DEVICES=0
# Within docker-compose-server.yml, use the qdrant service name: http://qdrant-siglip-alpha
SIGLIP_V2_QDRANT_URL=http://localhost
SIGLIP_V2_QDRANT_PORT=6333
SIGLIP_V2_QDRANT_GRPC_PORT=6334
SIGLIP_V2_DATABASE_NAME=SIGLIP_V2
SIGLIP_V2_FEATURES_PATH=["data/0/features/siglip2", "data/1/features/siglip2"]
SIGLIP_V2_FEATURES_SIZE=1536
SIGLIP_V2_DUMMY_VECTOR_PATH=data/example/cat_siglip2.npy

# --- SIGLIP v2 (beta) --- second model instance, separate Qdrant collection, for A/B comparison
SIGLIP_V2_B_HOST=0.0.0.0
SIGLIP_V2_B_PORT=9030
SIGLIP_V2_B_HOST_PUBLIC=http://your-server-host:9030
SIGLIP_V2_B_MAX_WORKERS=1
SIGLIP_V2_B_CUDA_VISIBLE_DEVICES=0
SIGLIP_V2_B_QDRANT_URL=http://localhost
SIGLIP_V2_B_QDRANT_PORT=7333
SIGLIP_V2_B_QDRANT_GRPC_PORT=7334
SIGLIP_V2_B_DATABASE_NAME=SIGLIP_V2_BETA
SIGLIP_V2_B_FEATURES_PATH=["data/0/features/siglip2", "data/1/features/siglip2"]
SIGLIP_V2_B_FEATURES_SIZE=1536
SIGLIP_V2_B_DUMMY_VECTOR_PATH=data/example/cat_siglip2.npy

# --- METACLIP --- third model variant; leave unset/disabled by not pointing SERVICE=metaclip at it
METACLIP_HOST=0.0.0.0
METACLIP_PORT=9031
METACLIP_HOST_PUBLIC=http://your-server-host:9031
METACLIP_MAX_WORKERS=1
METACLIP_CUDA_VISIBLE_DEVICES=0
METACLIP_QDRANT_URL=http://localhost
METACLIP_QDRANT_PORT=8333
METACLIP_QDRANT_GRPC_PORT=8334
METACLIP_DATABASE_NAME=METACLIP
METACLIP_FEATURES_PATH=["data/0/features/metaclip", "data/1/features/metaclip"]
METACLIP_FEATURES_SIZE=1024
METACLIP_DUMMY_VECTOR_PATH=data/example/cat_metaclip.npy

# --- Rerank (dominant-color re-sort) ---
RERANK_HOST=0.0.0.0
RERANK_PORT=9126
RERANK_HOST_PUBLIC=http://your-server-host:9126
RERANK_MAX_WORKERS=1
RERANK_COLOR_PATH=["data/0/rerank/dominant_color/autoshot", "data/1/rerank/dominant_color/autoshot"]

# --- Util (translate / neighboring frames / vector lookup) ---
UTIL_HOST=0.0.0.0
UTIL_PORT=9025
UTIL_HOST_PUBLIC=http://your-server-host:9025
UTIL_MAX_WORKERS=5
# Real Google Cloud Translate v2 API key. Rotate if ever leaked.
GG_TRANSLATE_API_KEY=
GG_TRANSLATE_ENDPOINT=https://translation.googleapis.com/language/translate/v2

# --- DRES submission (competition server) ---
SUBMISSION_HOST=0.0.0.0
SUBMISSION_PORT=9024
SUBMISSION_HOST_PUBLIC=http://your-server-host:9024
SUBMISSION_MAX_WORKERS=5
SUBMIT_BASE_URL=https://eventretrieval.oj.io.vn
SUBMIT_USERNAME=
SUBMIT_PASSWORD=

# --- VLM extractor (src/pre_processing/vlm_extractor) ---
PROMPT_TITLE_EXTRACTOR_PATH=src/pre_processing/vlm_extractor/prompt/title.txt
PROMPT_CAPTION_PATH=src/pre_processing/vlm_extractor/prompt/caption.txt
SUMMURAY_PROMPT_PATH=src/pre_processing/vlm_extractor/prompt/summuray.txt
OCR_PROMPT_PATH=src/pre_processing/vlm_extractor/prompt/ocr.txt
MODEL_QWEN25_WEIGHT_FOLDER=
MODEL_QWEN3_WEIGHT_FOLDER=
QWEN25_CUDA_VISIBLE_DEVICES=0
QWEN3_CUDA_VISIBLE_DEVICES=0
BASE_OUTPUT_CRAW_PATH=data/output_crawl
MAX_NEW_TOKENS_CAPTION=16384

# --- Logging ---
LOG_DIR=logs/
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_SERIALIZE_JSON=true
LOG_BACKTRACE=false
LOG_DIAGNOSE=false

# --- Which service this container/process should serve (src/main.py) ---
# One of: hub, siglip_alpha, siglip_beta, metaclip, rerank, submission, util, result_manager
SERVICE=hub
ENABLE_GZIP=true
